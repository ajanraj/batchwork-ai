# Copy to .env and fill in at least one provider credential.
# The demos default to OpenAI; only OPENAI_API_KEY is required for them.
OPENAI_API_KEY=sk-...

# Optional: try other providers by changing --model / the model string.
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=
# MISTRAL_API_KEY=
# TOGETHER_API_KEY=
# XAI_API_KEY=
