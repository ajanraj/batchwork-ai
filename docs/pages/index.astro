---
import PageLayout from "blume/components/layout/PageLayout.astro";
import data from "blume:data";

import Benefits from "../components/home/Benefits.astro";
import ClosingCta from "../components/home/ClosingCta.astro";
import Expansion from "../components/home/Expansion.astro";
import Footer from "../components/home/Footer.astro";
import Hero from "../components/home/Hero.astro";
import ProviderCoverage from "../components/home/ProviderCoverage.astro";
import ProviderSwitch from "../components/home/ProviderSwitch.astro";
import Stories from "../components/home/Stories.astro";
import "../styles/home.css";

const { config } = data;
const pageTitle = "Save up to 50% on AI batch costs | Batchwork for Python";
const pageDescription =
  "Run provider-native AI batch jobs across OpenAI, Anthropic, Google Gemini, Groq, Mistral, Together AI, and xAI through one typed async Python API.";

const pageScript = `(()=>{document.addEventListener("click",async(event)=>{const button=event.target.closest("[data-copy-command]");if(!button)return;const command=button.dataset.copyCommand;const label=button.querySelector("[data-copy-label]");const status=button.querySelector("[data-copy-status]");if(!command||!label||!status)return;try{await navigator.clipboard.writeText(command);label.textContent="Copied";status.textContent=command+" copied";setTimeout(()=>{label.textContent="Copy";status.textContent="";},1600);}catch{status.textContent="Copy unavailable. Select the command manually.";}});const items=[...document.querySelectorAll(".reveal")];if(matchMedia("(prefers-reduced-motion: reduce)").matches||!("IntersectionObserver" in window)){items.forEach((item)=>item.classList.add("is-visible"));return;}const observer=new IntersectionObserver((entries)=>{entries.forEach((entry)=>{if(entry.isIntersecting){entry.target.classList.add("is-visible");observer.unobserve(entry.target);}});},{rootMargin:"-64px"});items.forEach((item)=>observer.observe(item));})();`;
---

<PageLayout
  analytics={config.analytics}
  appleIcon={config.appleIcon}
  banner={config.banner}
  favicon={config.favicon}
  fontCssVars={data.fontCssVars}
  logo={config.logo}
  navigation={data.navigation}
  ogEnabled={config.og.enabled}
  ogImage="/og-image.png?v=2"
  page={{ description: pageDescription, route: "/", title: pageTitle }}
  searchEnabled={config.search.enabled}
  site={{ description: config.description, title: config.title }}
  siteUrl={config.site}
  themeMode={config.theme.mode}
>
  <Hero />
  <Benefits />
  <ProviderSwitch />
  <Stories />
  <ProviderCoverage />
  <Expansion />
  <ClosingCta />
  <Footer slot="footer" />
  <script is:inline set:html={pageScript} />
</PageLayout>
