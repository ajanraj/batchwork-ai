  "xai": {
    "endpoint": "/v1/responses",
    "body": {
      "model": "model",
      "input": [
        {"role": "user", "content": [{"type": "input_text", "text": "hello"}]},
        {"role": "assistant", "content": "answer"},
        {
          "type": "function_call",
          "id": "call-1",
          "call_id": "call-1",
          "name": "lookup",
          "arguments": "{\"q\":1}",
          "status": "completed"
        },
        {"type": "function_call_output", "call_id": "call-1", "output": "plain"}
      ],
      "max_output_tokens": 64,
      "temperature": 0.5,
      "top_p": 0.9,
      "seed": 42
    }
  }
