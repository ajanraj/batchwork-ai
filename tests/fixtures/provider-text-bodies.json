      "messages": [
        {"role": "user", "content": [{"type": "text", "text": "hello"}]},
        {
          "role": "assistant",
          "content": "thoughtanswer",
          "tool_calls": [
            {
              "id": "call-1",
              "type": "function",
              "function": {"name": "lookup", "arguments": "{\"q\":1}"}
            }
          ]
        },
        {"role": "tool", "name": "lookup", "tool_call_id": "call-1", "content": "plain"}
      ]
    }
  },
